<!DOCTYPE html>
<html lang="en">
<body>
    <h1>Your Personalised Watch List</h1>
    <p>Below are your movies. You can update their watched status.</p>

    <form action= '/update-status' method='post'>
    <table border ='1'>
        <tr>
        <th>
            Movie Information
        </th>
        <th>
            Watched?
        </th>
        </tr>

        <% moviesList.forEach(movie =>{%>
            <tr>
                <td>
                    <strong><%=movie.title %></strong><br>
                    Year: <%=movie.releaseYear %><br>
                    Category: <%=movie.category %><br>
                    Sypnosis: <%=movie.sypnosis%><br>
                    Runtime: <%=movie.runTime %><br>
                    Director: <%=movie.director %><br>
                    Image: <%=movie.image%> <br>
                    <a href="/review">Leave a review?</a>
                </td>
                <td>        
                    <input type="checkbox" name ='watched'value='<%=movie._id%>'
                    <%= movie.isWatched? "checked" : "" %>>
                </td>
            </tr>
            <% }) %>
    </table>

    <br>
    <button type ='submit'>Update</button>
</form>
</body>
</html>